# ──────────────────────────────────────────────────────────────────────────────
# Plantilla de variables de entorno
# Copia este archivo como .env y rellena los valores
# ──────────────────────────────────────────────────────────────────────────────

# Genera una clave segura con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-segura

# False en producción, True solo en desarrollo local
DEBUG=False

# Tu(s) dominio(s) separados por coma: miestudio.com,www.miestudio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL recomendado en producción; dejar vacío en dev para usar SQLite
# Formato: postgres://usuario:contraseña@host:5432/nombre_db
DATABASE_URL=

# Correo real en producción (quitar la línea EMAIL_BACKEND para usar SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu@correo.com
EMAIL_HOST_PASSWORD=contraseña-de-aplicacion
DEFAULT_FROM_EMAIL=estudio@tatuajes.com
